# =============================================================================
# events.coreviaflow.space — Meta CAPI proxy
# =============================================================================

# ID Pixel'я (Meta Events Manager).
FACEBOOK_PIXEL_ID=1485718672417519

# Access token. Можна використати system user token (той що в CRM .env.local),
# або згенерувати окремий через Business Manager → System Users → Generate Token
# з permission ads_management. Краще — окремий, обмежений тільки на CAPI.
FACEBOOK_CAPI_TOKEN=

# Версія Graph API.
FACEBOOK_API_VERSION=v21.0

# Shared secret для server-to-server подій (Monobank webhook → CAPI).
# Згенерувати: openssl rand -hex 32
EVENTS_SECRET=

# Test Event Code з Events Manager — у час налаштування пуш події з'являються
# в реальному часі в Events Manager → Test Events. Залишити порожнім у проді.
META_TEST_EVENT_CODE=

PORT=8080
